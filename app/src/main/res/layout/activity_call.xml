<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_dark">

    <!-- ============================================================
         HEADER: caller info + duration
         ============================================================ -->
    <LinearLayout
        android:id="@+id/layoutCallerInfo"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        android:paddingTop="52dp"
        android:paddingBottom="20dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <TextView
            android:id="@+id/tvCallerName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Connecting…"
            android:textSize="30sp"
            android:textColor="@color/white"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvCallerPhone"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="15sp"
            android:textColor="@color/text_secondary"
            android:layout_marginTop="4dp" />

        <TextView
            android:id="@+id/tvCallCount"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="12sp"
            android:textColor="@color/call_active"
            android:layout_marginTop="2dp" />

        <TextView
            android:id="@+id/tvCallDuration"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="00:00"
            android:textSize="22sp"
            android:textColor="@color/white"
            android:layout_marginTop="8dp" />
    </LinearLayout>

    <!-- ============================================================
         AI STATUS BAR
         ============================================================ -->
    <LinearLayout
        android:id="@+id/layoutAiStatus"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="16dp"
        android:background="#1A1A2E"
        app:layout_constraintTop_toBottomOf="@id/layoutCallerInfo"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <View
            android:id="@+id/viewAiIndicator"
            android:layout_width="12dp"
            android:layout_height="12dp"
            android:background="@drawable/circle_indicator" />

        <TextView
            android:id="@+id/tvAiStatus"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="AI Receptionist Active"
            android:textColor="@color/white"
            android:textSize="14sp"
            android:layout_marginStart="10dp" />

        <ProgressBar
            android:id="@+id/progressAi"
            android:layout_width="22dp"
            android:layout_height="22dp"
            android:visibility="gone"
            android:layout_marginEnd="8dp" />

        <TextView
            android:id="@+id/tvEmotion"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="13sp"
            android:textColor="@color/text_secondary"
            android:visibility="gone" />
    </LinearLayout>

    <!-- ============================================================
         LIVE TRANSCRIPT
         ============================================================ -->
    <androidx.cardview.widget.CardView
        android:id="@+id/cardTranscript"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_margin="12dp"
        app:cardCornerRadius="12dp"
        app:cardBackgroundColor="#1E1E2E"
        app:layout_constraintTop_toBottomOf="@id/layoutAiStatus"
        app:layout_constraintBottom_toTopOf="@id/cardAiResponse"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:padding="14dp">

            <TextView
                android:id="@+id/tvTranscript"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Listening…"
                android:textColor="@color/text_primary"
                android:textSize="16sp"
                android:lineSpacingExtra="5dp" />
        </ScrollView>
    </androidx.cardview.widget.CardView>

    <!-- ============================================================
         AI RESPONSE BUBBLE
         ============================================================ -->
    <androidx.cardview.widget.CardView
        android:id="@+id/cardAiResponse"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="12dp"
        android:layout_marginBottom="8dp"
        android:visibility="gone"
        app:cardCornerRadius="12dp"
        app:cardBackgroundColor="#162447"
        app:layout_constraintBottom_toTopOf="@id/layoutCallControls"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <TextView
            android:id="@+id/tvAiResponse"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="14dp"
            android:textColor="@color/white"
            android:textSize="15sp"
            android:lineSpacingExtra="4dp" />
    </androidx.cardview.widget.CardView>

    <!-- ============================================================
         CALL CONTROLS
         ============================================================ -->
    <LinearLayout
        android:id="@+id/layoutCallControls"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingHorizontal="16dp"
        android:paddingBottom="36dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- Row 1: Mute | Hold | Transfer -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"
            android:layout_marginBottom="14dp">

            <Button
                android:id="@+id/btnMute"
                style="@style/Widget.Material3.Button.OutlinedButton"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:layout_marginEnd="6dp"
                android:text="Mute"
                android:textColor="@color/white" />

            <Button
                android:id="@+id/btnHold"
                style="@style/Widget.Material3.Button.OutlinedButton"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:layout_marginHorizontal="6dp"
                android:text="Hold"
                android:textColor="@color/white" />

            <Button
                android:id="@+id/btnTransfer"
                style="@style/Widget.Material3.Button.OutlinedButton"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:layout_marginStart="6dp"
                android:text="Transfer"
                android:textColor="@color/white" />
        </LinearLayout>

        <!-- Row 2: Speaker | End Call (FAB) -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <Button
                android:id="@+id/btnSpeaker"
                style="@style/Widget.Material3.Button.OutlinedButton"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:layout_marginEnd="16dp"
                android:text="Speaker"
                android:textColor="@color/white" />

            <com.google.android.material.floatingactionbutton.FloatingActionButton
                android:id="@+id/btnEndCall"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:src="@android:drawable/ic_menu_close_clear_cancel"
                android:contentDescription="End call"
                app:backgroundTint="@color/call_ended"
                app:fabSize="normal" />
        </LinearLayout>
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
