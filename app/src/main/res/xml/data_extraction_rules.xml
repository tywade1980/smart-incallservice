<?xml version="1.0" encoding="utf-8"?>
<!--
  Defines which app data is included / excluded from Android’s
  cloud backup and device-to-device transfer features.
-->
<data-extraction-rules>
    <cloud-backup>
        <!-- Back up user preferences but not the local DB (contains PII) -->
        <include domain="sharedpref" path="." />
        <exclude domain="database" path="." />
        <exclude domain="file"      path="models/" />
        <exclude domain="file"      path="recordings/" />
    </cloud-backup>
    <device-transfer>
        <include domain="sharedpref" path="." />
        <exclude domain="database"   path="." />
    </device-transfer>
</data-extraction-rules>
